# =========================================================
# DOMAINRELAY - ROOT .gitignore
# .NET / NuGet / Source Generators / Tests / Samples
# =========================================================

# ---------------------------------------------------------
# Build output
# ---------------------------------------------------------
[Bb]in/
[Oo]bj/
out/
artifacts/
TestResults/
BenchmarkDotNet.Artifacts/

# ---------------------------------------------------------
# User-specific files
# ---------------------------------------------------------
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# ---------------------------------------------------------
# Visual Studio
# ---------------------------------------------------------
.vs/
*.VC.db
*.VC.VC.opendb

# ---------------------------------------------------------
# Rider / ReSharper
# ---------------------------------------------------------
.idea/
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# ---------------------------------------------------------
# VS Code
# ---------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
*.log
logs/
log/
*.tlog

# ---------------------------------------------------------
# OS files
# ---------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------
# NuGet
# ---------------------------------------------------------
*.nupkg
*.snupkg
*.nuspec
packages/
*.nuget.props
*.nuget.targets

# Keep lock file only if you intentionally want it versioned
# packages.lock.json

# ---------------------------------------------------------
# Local feeds / package caches
# ---------------------------------------------------------
.nupkg/
.nuget/
.nuget/packages/

# ---------------------------------------------------------
# SourceLink / symbols / debugging artifacts
# ---------------------------------------------------------
*.pdb
*.mdb

# ---------------------------------------------------------
# Coverage / test artifacts
# ---------------------------------------------------------
coverage/
coverage.*
*.coverage
*.coveragexml
*.trx
*.lcov
lcov.info

# ---------------------------------------------------------
# Generated files
# ---------------------------------------------------------
Generated/
generated/
*.generated.cs
*.g.cs
*.g.i.cs

# Keep Razor/Designer generated files ignored by default
*.designer.cs
*.AssemblyInfo.cs

# ---------------------------------------------------------
# Source generator outputs (common temp folders)
# ---------------------------------------------------------
obj2/
GeneratedFiles/
CompilerGeneratedFilesOutputPath/

# ---------------------------------------------------------
# Publish artifacts
# ---------------------------------------------------------
publish/
app.publish/
*.Publish.xml

# ---------------------------------------------------------
# Dotnet local tools / temporary files
# ---------------------------------------------------------
.dotnet/
.dotnet-tools/
*.tmp
*.temp
tmp/
temp/

# ---------------------------------------------------------
# Profiling / diagnostics
# ---------------------------------------------------------
*.etl
*.trace
*.dmp
*.dump

# ---------------------------------------------------------
# SQL / local DB files
# ---------------------------------------------------------
*.mdf
*.ldf
*.db
*.sqlite
*.sqlite3

# ---------------------------------------------------------
# Node (only if some samples/docs use it)
# ---------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------
# Frontend build leftovers inside samples/docs
# ---------------------------------------------------------
dist/
build/

# ---------------------------------------------------------
# Azure / CI local secrets
# ---------------------------------------------------------
secrets.json
appsettings.Development.json
appsettings.Local.json
.env
.env.*
!.env.example

# ---------------------------------------------------------
# Cake / FAKE / Nuke / script temp
# ---------------------------------------------------------
.tools/
.nuke/temp/
.nuke/builds/

# ---------------------------------------------------------
# Documentation generated output
# ---------------------------------------------------------
site/
docs/_site/

# ---------------------------------------------------------
# JetBrains / dotCover / test runners
# ---------------------------------------------------------
*.dotCover
*.dotCover.html

# ---------------------------------------------------------
# Paket
# ---------------------------------------------------------
.paket/
paket-files/

# ---------------------------------------------------------
# F# / Mono / legacy extras
# ---------------------------------------------------------
*.pidb
*.svclog
*.scc

# ---------------------------------------------------------
# Keep important repository files tracked
# ---------------------------------------------------------
!.editorconfig
!.gitattributes
!.gitignore
!Directory.Build.props
!Directory.Build.targets
!Directory.Packages.props
!global.json
!NuGet.config
!README.md
!CHANGELOG.md
!LICENSE
!*.md

# ---------------------------------------------------------
# Keep GitHub workflows and config tracked
# ---------------------------------------------------------
!.github/
!.github/workflows/**
!.github/**/*.yml
!.github/**/*.yaml